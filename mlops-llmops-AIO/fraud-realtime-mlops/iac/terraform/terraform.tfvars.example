region                            = "us-east-1"
environment                       = "prod"
endpoint_name                     = "fraud-realtime-endpoint"
model_name                        = "fraud-realtime-model-v314"
endpoint_config_name              = "fraud-realtime-endpoint-config-v314"
image_uri                         = "123456789012.dkr.ecr.us-east-1.amazonaws.com/fraud-inference:sha-abc123"
model_data_url                    = "s3://fin-ml-artifacts/fraud/model-v314/model.tar.gz"
instance_type                     = "ml.c7i.2xlarge"
initial_instance_count            = 4
min_capacity                      = 4
max_capacity                      = 20
target_invocations_per_instance   = 120
execution_role_name               = "SageMakerEndpointExecutionRoleFraudRealtime"
deployment_role_arn               = "arn:aws:iam::123456789012:role/DeploymentPipelineRoleProd"
subnet_ids                        = ["subnet-111111", "subnet-222222"]
security_group_ids                = ["sg-111111"]
kms_key_id                        = "arn:aws:kms:us-east-1:123456789012:key/1111-2222-3333-4444"
model_artifact_bucket_arn         = "arn:aws:s3:::fin-ml-artifacts"
cloudwatch_log_group_arn          = "arn:aws:logs:us-east-1:123456789012:log-group:/aws/sagemaker/Endpoints/fraud-realtime-endpoint"
alert_sns_topic_arn               = "arn:aws:sns:us-east-1:123456789012:fraud-prod-alerts"
