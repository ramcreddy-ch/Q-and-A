{
  "title": "card_auth_event_v1",
  "type": "object",
  "required": [
    "event_id",
    "event_ts",
    "account_id",
    "merchant_id",
    "transaction_amount",
    "currency",
    "device_id",
    "channel"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_ts": { "type": "string" },
    "account_id": { "type": "string" },
    "merchant_id": { "type": "string" },
    "transaction_amount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "enum": ["USD", "EUR", "GBP"] },
    "device_id": { "type": "string" },
    "ip_address": { "type": "string" },
    "channel": { "type": "string", "enum": ["card_present", "ecommerce", "wallet", "bank_transfer"] },
    "merchant_country": { "type": "string" }
  }
}
